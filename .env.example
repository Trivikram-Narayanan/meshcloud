# MeshCloud Configuration Template
# Copy this file to .env and customize the values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Node Configuration
NODE_URL=https://localhost:8000
NODE_NAME=meshcloud-node
DISCOVERY_PORT=9999

# Security Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Node Authentication (for inter-node communication)
MESH_NODE_TOKEN=your-secure-node-token-here

# Database Configuration
DATABASE_URL=sqlite:///db/meshcloud.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Storage Configuration
STORAGE_DIR=storage
MAX_FILE_SIZE=104857600  # 100MB in bytes

# Network Configuration
REQUEST_TIMEOUT=30
MAX_RETRIES=3
BACKOFF_FACTOR=0.3

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/meshcloud.log
LOG_MAX_SIZE=10 MB
LOG_RETENTION=1 week

# Peer Configuration
PEERS_FILE=config/peers.json
AUTO_DISCOVERY=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# SSL/TLS Configuration (for production)
SSL_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=

# CORS Configuration (restrict in production)
CORS_ORIGINS=*

# Environment
ENVIRONMENT=development